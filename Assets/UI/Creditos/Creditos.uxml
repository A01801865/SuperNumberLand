    <ui:VisualElement name="Fondo" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/Wood%20UI/Sprites/Borders/ExamplesLikeBorders/Inventory.png?fileID=21300000&amp;guid=2a858408be4776b4486c986c764b4850&amp;type=3#Inventory&quot;); position: absolute; width: 1600px; height: 900px; align-self: center; justify-content: flex-start; align-content: flex-start; align-items: stretch; bottom: 150px; display: flex;">
        <ui:Label text="Créditos" name="Titulo" style="position: absolute; font-size: 60px; -unity-font-definition: resource(&quot;PressStart2P&quot;); align-self: center; top: 50px; color: rgb(255, 255, 255); -unity-text-outline-width: 3px; -unity-text-outline-color: rgb(0, 0, 0); text-shadow: 0 2px 0 rgb(0, 0, 0);"/>
        <ui:ScrollView style="height: 600px; position: absolute; width: 1295px; left: 150px; top: 170px; justify-content: flex-start; align-items: flex-start; align-content: flex-start; align-self: flex-start;">
            <ui:VisualElement name="Informacion" style="flex-grow: 1; background-size: 100% 100%; position: absolute; top: 304px; left: 8px; align-self: center; margin-top: -300px;">
                <ui:Label text="Creado por:" name="Inicio" class="texto" style="position: relative; font-size: 40px; top: auto; left: auto; align-self: center;"/>
                <ui:Label text="Gilberto de Jesús Marcos Orozco" name="Gilberto" class="texto" style="position: relative; font-size: 39px; top: auto; left: auto;"/>
