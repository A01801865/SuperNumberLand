                <ui:Label text="Joshua Michel Martínez Orozco" name="Joshua" class="texto" style="position: relative; font-size: 39px; top: auto; left: auto;"/>
                <ui:Label text="Diego Alexander Cisneros Ramos&#10;" name="DiegoC" class="texto" style="position: relative; font-size: 39px; top: auto; left: auto;"/>
                <ui:Label text="Maximiliano Arriaga Navarro" name="Maximiliano" class="texto" style="position: relative; font-size: 39px; top: auto; left: auto;"/>
                <ui:Label text="" name="Espacio" class="texto"/>
                <ui:Label text="SuperNumberland fue creado con el objetivo de ayudar a los estudiantes de la fundación NIDE a que practiquen  matemáticas de forma interactiva, divertida y motivadora, mientras progresan en el juego y desbloquean recompensas como monedas, skins y accesorios." name="Info" class="texto text-height" style="white-space: pre-wrap; width: 1250px; -unity-paragraph-spacing: 0; height: 436px; font-size: 39px; word-spacing: 0; letter-spacing: 5px; -unity-text-generator: standard; -unity-text-align: upper-center; -unity-text-auto-size: none; text-overflow: clip;"/>
            </ui:VisualElement>
