<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/HUD/UIHUD.uss?fileID=7433441132597879392&amp;guid=b4a4ee18805b2413db76d282159208c6&amp;type=3#UIHUD"/>
    <ui:VisualElement name="Contenedor" class="contenedor" style="flex-grow: 1;">
        <ui:VisualElement name="HUD" class="hud" style="flex-grow: 1; position: absolute; display: flex; top: 10px; left: 0;">
            <ui:VisualElement name="Vidas" class="vidas" style="flex-grow: 1; position: absolute; top: 10px; left: -1px; display: flex; height: auto; width: auto; bottom: 20px;">
                <ui:VisualElement name="Vida_1" class="vida" style="flex-grow: 1; position: absolute; top: -7px; left: 20px; height: 120px; width: 120px;"/>
                <ui:VisualElement name="Vida_2" class="vida" style="flex-grow: 1; position: absolute; top: -9px; left: 139px; height: 120px; width: 120px;"/>
                <ui:VisualElement name="Vida_3" class="vida" style="flex-grow: 1; position: absolute; top: -10px; left: 256px; height: 120px; width: 120px;"/>
            </ui:VisualElement>
            <ui:VisualElement name="Espacio" class="espacio" style="flex-grow: 1; width: 50%; position: relative;"/>
            <ui:VisualElement name="Monedas" class="monedas" style="flex-grow: 1; position: relative; top: 20px; left: auto; flex-direction: row; justify-content: space-around; align-content: flex-start; flex-wrap: nowrap;">
                <ui:Label text="0" name="NumeroMonedas" style="-unity-font-definition: resource(&quot;PressStart2P&quot;); font-size: 55px; color: rgb(255, 255, 255); -unity-text-align: middle-right; -unity-text-outline-width: 4px; -unity-text-outline-color: rgb(0, 0, 0); text-shadow: 0 1px 0 rgb(0, 0, 0); position: relative; top: -13px; left: -70px; -unity-font-style: bold; border-right-width: 0; flex-grow: 1; flex-direction: row-reverse; align-self: flex-start; justify-content: center; align-items: center; align-content: flex-end;"/>
                <ui:VisualElement name="Moneda" style="flex-grow: 0; background-image: url(&quot;project://database/Assets/Monedas/coin3_16x16.png?fileID=7717009168347922525&amp;guid=c0ac2887a513d7245bfa14c87f5ccf6e&amp;type=3#coin3_16x16_0&quot;); width: 55px; height: 55px; flex-direction: row; position: relative; bottom: 93px; left: -70px; right: 83px; top: -60px;"/>
            </ui:VisualElement>
            <ui:VisualElement name="fondoPregunta" style="flex-grow: 1; width: 823px; height: 77px; align-self: center; justify-content: center; align-items: center; background-image: url(&quot;project://database/Assets/Wood%20UI/Sprites/Buttons/16x16.png?fileID=1940803569&amp;guid=584ea5e1f4128f842936858238ac18b1&amp;type=3#16x16_11&quot;); position: absolute; top: 10px; left: 607px; -unity-slice-left: 5; -unity-slice-top: 5; -unity-slice-right: 5; -unity-slice-bottom: 5; -unity-background-image-tint-color: rgb(233, 150, 122);">
                <ui:Label text="Label " name="preguntaLabel" style="-unity-text-outline-color: rgb(0, 0, 0); color: rgb(255, 255, 255); -unity-font-definition: url(&quot;project://database/Assets/Resources/ARCADECLASSIC.TTF?fileID=12800000&amp;guid=2fd92e0f1a30cfd40b90cb5ca04a9372&amp;type=3#ARCADECLASSIC&quot;); font-size: 50px; -unity-text-outline-width: 3px; text-shadow: 0 1px 0 rgb(0, 0, 0); letter-spacing: 0; -unity-font-style: bold; width: auto;"/>
