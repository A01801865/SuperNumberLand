        </ui:VisualElement>
        <ui:VisualElement name="Pausa" class="pausa" style="flex-grow: 1; position: relative; background-color: rgba(0, 0, 0, 0.51); display: none;">
            <ui:VisualElement name="FondoPausa" class="fondopausa" style="flex-grow: 1;">
                <ui:Label text="Pausa" name="TituloPausa" style="font-size: 90px; -unity-font-definition: resource(&quot;PressStart2P&quot;); color: rgb(255, 255, 255); -unity-text-outline-width: 4px; -unity-text-outline-color: rgb(0, 0, 0); text-shadow: 0 5px 0 rgb(0, 0, 0); background-image: url(&quot;project://database/Assets/Wood%20UI/Sprites/Borders/Original/Titlebox.png?fileID=21300000&amp;guid=54214d0dae9aadd49a6c31b28cc135de&amp;type=3#Titlebox&quot;); -unity-slice-left: 30; -unity-slice-top: 30; -unity-slice-right: 30; -unity-slice-bottom: 30; width: 600px; height: 200px; align-self: center; -unity-text-align: middle-center; position: absolute; top: 77px; left: 656px;"/>
