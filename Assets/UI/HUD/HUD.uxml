                    <ui:VisualElement name="Estrella_1" style="flex-grow: 1; width: 200px; height: 200px; background-image: url(&quot;project://database/Assets/Logos/pixil-frame-0%20copy%203.png?fileID=154673233858023292&amp;guid=08375c589f6074921bcb735f3fdf9c8b&amp;type=3#pixil-frame-0 copy 3_0&quot;); display: none;"/>
                    <ui:VisualElement name="Estrella_2" style="flex-grow: 1; width: 250px; height: 250px; background-image: url(&quot;project://database/Assets/Logos/pixil-frame-0%20copy%203.png?fileID=154673233858023292&amp;guid=08375c589f6074921bcb735f3fdf9c8b&amp;type=3#pixil-frame-0 copy 3_0&quot;); display: none;"/>
                    <ui:VisualElement name="Estrella_3" style="flex-grow: 1; width: 200px; height: 200px; background-image: url(&quot;project://database/Assets/Logos/pixil-frame-0%20copy%203.png?fileID=154673233858023292&amp;guid=08375c589f6074921bcb735f3fdf9c8b&amp;type=3#pixil-frame-0 copy 3_0&quot;); display: none;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="Perder" class="pausa" style="flex-grow: 1; position: relative; background-color: rgba(255, 0, 0, 0.18); display: none; -unity-background-image-tint-color: rgb(255, 0, 0);">
